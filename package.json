{
  "name": "ethan-dapp-web",
  "version": "2.2.12",
  "author": "0xEthan",
  "private": true,
  "overrides": {
    "valibot": "1.4.1"
  },
  "dependencies": {
    "@bric-labs/bric-sdk": "^0.3.9",
    "@coral-xyz/anchor": "^0.30.1",
    "@noble/ed25519": "^2.0.0",
    "@opensea/sdk": "^11.1.0",
    "@opensea/seaport-js": "^4.1.3",
    "@reown/appkit": "^1.8.20",
    "@reown/appkit-adapter-bitcoin": "^1.8.20",
    "@reown/appkit-adapter-ethers": "^1.8.20",
    "@reown/appkit-adapter-solana": "^1.8.20",
    "@snapshot-labs/snapshot.js": "^0.12.32",
    "@solana/spl-token": "0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tokenbound/sdk": "^0.4.5",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@web3auth/base": "^9.4.4",
    "@web3auth/ethereum-provider": "^9.4.4",
    "@web3auth/modal": "^9.4.4",
    "@web3auth/solana-provider": "^9.4.4",
    "alchemy-sdk": "^3.2.0",
    "bs58": "^5.0.0",
    "bulkorder-sdk": "^0.0.4",
    "dotenv": "^16.0.3",
    "eth-url-parser": "^1.0.4",
    "ethers": "^6.16.0",
    "lightweight-charts": "^5.2.0",
    "qr-code-styling": "^1.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "siwe": "^3.0.0",
    "sonner": "^2.0.6",
    "tweetnacl": "^1.0.3"
  },
  "lint-staged": {
    "{src,tests}/**/*.{js,ts,tsx,json,css,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "scripts": {
    "prepare": "husky install",
    "prettier": "bun x prettier --write \"{src,tests}/**/*.{js,ts,tsx,json,css,md}\"",
    "typecheck": "bun x tsc --noEmit",
    "start": "bun x vite",
    "build": "bun x vite build",
    "preview": "bun x vite preview",
    "release": "bun x standard-version --release-as patch"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "off",
      "no-unused-vars": "off",
      "import/no-anonymous-default-export": "off",
      "react-hooks/exhaustive-deps": "off",
      "react/jsx-no-target-blank": "off",
      "no-useless-concat": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "buffer": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "process": "^0.11.10",
    "react-refresh": "^0.11.0",
    "source-map-loader": "^4.0.1",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.3",
    "vite": "^8.1.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
